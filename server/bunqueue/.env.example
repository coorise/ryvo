############
# Bunqueue (task / cron, TCP server mode)
# Copy to .env: cp .env.example .env
# Docs: https://github.com/egeominotti/bunqueue#server-mode-tcp
############

BUNQUEUE_CONTAINER_NAME=ryvo_bunqueue
BUNQUEUE_HTTP_PORT=6789
BUNQUEUE_TCP_PORT=6790

# Used by Ryvo edge functions / services
BUNQUEUE_HOST=ryvo_bunqueue
BUNQUEUE_PORT=6789
