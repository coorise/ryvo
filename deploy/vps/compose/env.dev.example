# Docker Compose orchestration — DEV
# Generated by apply-env.sh → deploy/vps/compose/.env.dev
# Secrets (ANON_KEY, GOOGLE_MAPS_API_KEY) come from server/supabase/.env — not duplicated here.

# Docker Hub (VPS pull + deploy-bluegreen.sh login)
DOCKER_IMAGE_PREFIX=coorise
DOCKER_USERNAME=coorise
DOCKER_TOKEN=REPLACE_WITH_DOCKER_HUB_PAT

RYVO_NETWORK_NAME=ryvo-net-dev

RYVO_ADMIN_PORT=3400
RYVO_CLIENT_PORT=3500
RYVO_API_PORT=8500

# Baked into Next.js images at build time (ANON_KEY filled from server/supabase/.env)
NEXT_PUBLIC_SUPABASE_URL=https://ryvo-line-server.dev.agglomy.com
NEXT_PUBLIC_FUNCTIONS_URL=https://ryvo-line-server.dev.agglomy.com/functions/v1
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_FROM_SUPABASE_ENV
NEXT_PUBLIC_APP_ENV=development

# External APIs (filled from server/supabase/.env via apply-env.sh)
GOOGLE_MAPS_API_KEY=REPLACE_FROM_SUPABASE_ENV
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=REPLACE_FROM_SUPABASE_ENV

SUPABASE_ENV_FILE=./server/supabase/.env
KAFKA_ENV_FILE=./server/kafka/.env
REDIS_ENV_FILE=./server/redis/.env
BUNQUEUE_ENV_FILE=./server/bunqueue/.env
