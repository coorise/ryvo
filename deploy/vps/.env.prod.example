# Docker Compose orchestration — PROD (copy → deploy/vps/.env.prod via apply-env.sh)

RYVO_NETWORK_NAME=ryvo-net

RYVO_ADMIN_PORT=3200
RYVO_CLIENT_PORT=3300
RYVO_API_PORT=8400

NEXT_PUBLIC_SUPABASE_URL=https://ryvo-line-server.agglomy.com
NEXT_PUBLIC_FUNCTIONS_URL=https://ryvo-line-server.agglomy.com/functions/v1
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_FROM_SUPABASE_ENV
NEXT_PUBLIC_APP_ENV=production

SUPABASE_ENV_FILE=./server/supabase/.env
KAFKA_ENV_FILE=./server/kafka/.env
REDIS_ENV_FILE=./server/redis/.env
BUNQUEUE_ENV_FILE=./server/bunqueue/.env
